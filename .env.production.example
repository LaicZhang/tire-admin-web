# Copy to .env.production for production builds (or inject via CI)
VITE_PUBLIC_PATH = /
VITE_ROUTER_HISTORY = "hash"
VITE_CDN = false
VITE_COMPRESSION = "both-clear"
VITE_SERVER_URL = "https://api.example.com"
# FSW-004: production default HttpOnly cookie mode (requires same-site + CSRF)
VITE_USE_HTTPONLY_COOKIE=true
